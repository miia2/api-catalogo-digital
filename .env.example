# Exemplo de configuração de ambiente para o Catálogo Digital
# Renomeie este arquivo para apenas '.env' e preencha com seus dados reais

# Se quiser usar PostgreSQL (Neon, Render, etc), cole a URL abaixo. 
# Se deixar em branco ou comentar, o sistema usará o SQLite local automaticamente.
DATABASE_URL=postgresql://seu_usuario:sua_senha@seu_host.tech/seu_banco?sslmode=require

# Crie uma chave longa e aleatória para assinar os tokens JWT de login
SECRET_KEY=sua_chave_secreta_aqui_muito_longa_e_segura

# Configurações padrão de criptografia
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60